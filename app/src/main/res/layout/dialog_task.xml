<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:layoutDirection="rtl"
    android:padding="16dp">

    <TextView android:id="@+id/tvTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView android:id="@+id/tvTaskStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_status_bg"
            android:textSize="12sp"
            android:textColor="@color/accent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="8dp"/>

        <TextView android:id="@+id/tvTaskPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/muted"
            android:layout_marginEnd="8dp"/>

        <TextView android:id="@+id/tvTaskAssigned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/muted"/>

    </LinearLayout>

    <!-- Thread messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvThread"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"/>

    <!-- Status buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button android:id="@+id/btnSetPending"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="⏳ معلقة"
            android:textSize="11sp"
            android:background="@drawable/btn_status_bg"
            android:textColor="@color/gold"
            android:layout_marginEnd="4dp"/>

        <Button android:id="@+id/btnSetProgress"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🔄 جارية"
            android:textSize="11sp"
            android:background="@drawable/btn_status_bg"
            android:textColor="@color/accent"
            android:layout_marginEnd="4dp"/>

        <Button android:id="@+id/btnSetDone"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="✅ منجزة"
            android:textSize="11sp"
            android:background="@drawable/btn_status_bg"
            android:textColor="@color/green"/>

    </LinearLayout>

    <!-- Reply box -->
    <EditText android:id="@+id/etReply"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="اكتب رد..."
        android:textColorHint="@color/muted"
        android:textColor="@color/text"
        android:background="@drawable/input_bg"
        android:padding="12dp"
        android:gravity="top|end"
        android:inputType="textMultiLine"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnSendReply"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="إرسال الرد"
        android:textStyle="bold"
        android:background="@drawable/btn_primary_bg"
        android:textColor="#ffffff"/>

</LinearLayout>
